{
  "name": "toppy/twig-view-model",
  "description": "Twig integration for async view models - view() and pre_load_view() functions",
  "type": "library",
  "license": "proprietary",
  "autoload": {
    "psr-4": {
      "Toppy\\TwigViewModel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Toppy\\TwigViewModel\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.4",
    "toppy/async-view-model": "*@dev",
    "twig/twig": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5",
    "symfony/dependency-injection": "^8.0",
    "symfony/http-kernel": "^8.0"
  },
  "suggest": {
    "symfony/dependency-injection": "Required for ToppyTwigViewModelBundle"
  },
  "extra": {
    "symfony": {
      "bundles": {
        "Toppy\\TwigViewModel\\Bundle\\ToppyTwigViewModelBundle": [
          "all"
        ]
      }
    },
    "branch-alias": {
      "dev-main": "0.x-dev"
    }
  }
}
